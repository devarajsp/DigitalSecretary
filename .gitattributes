# Normalize text line endings; keep binaries intact.
* text=auto

*.cs        text
*.csproj    text
*.props     text
*.json      text
*.md        text
*.ps1       text
*.py        text
*.html      text
*.runsettings text
.editorconfig text

# Binary assets (never normalize/diff as text)
*.png  binary
*.xlsx binary
*.ico  binary
*.dll  binary
