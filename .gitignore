# Build output
bin/
obj/

# Python bytecode cache (build artifact; .pyc embeds the absolute source path = username PII — never track)
__pycache__/
*.pyc

# Test & coverage artifacts
artifacts/
TestResults/
*.trx
coverage.cobertura.xml

# Per-run quality report (regenerated by build.ps1 each run; do not track the timestamped output)
docs/QUALITY_REPORT.md

# Release artifacts are distributed via GitHub Releases, not committed (keep only the README).
release/*
!release/README.md

# User-specific
*.user
*.suo
.vs/

# Rider / VS Code
.idea/
.vscode/
