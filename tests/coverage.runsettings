<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <!--
            Coverage tracks TESTABLE LOGIC. WinForms views/forms, the bootstrap entry point,
            the plugin loader, and the IMAP networking class are validated by QA automation
            (DigitalSecretary.QaTests) and manual runs, not by unit tests, so they are excluded
            from the unit-coverage metric to keep it meaningful.
          -->
          <Exclude>[*]*Control,[*]*Form,[*]*Module,[*]*Program,[*]*Prompt,[*]*PluginLoader,[*]*PluginLoadContext,[*]*LoadedFeature,[DigitalSecretary.Features.EmailDownloader]*.EmailDownloader,[DigitalSecretary.Features.GmailDownloader]*.GmailDownloader,[DigitalSecretary.Features.GoogleDriveDownloader]*.GoogleDriveDownloader</Exclude>
          <ExcludeByAttribute>GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
          <SkipAutoProps>true</SkipAutoProps>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
